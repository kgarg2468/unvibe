{
  "name": "unvibe",
  "version": "0.1.0-alpha.0",
  "description": "Learning-first planning orchestration for Codex CLI.",
  "type": "module",
  "bin": {
    "unvibe": "dist/cli.js"
  },
  "files": [
    "dist",
    "content",
    "README.md"
